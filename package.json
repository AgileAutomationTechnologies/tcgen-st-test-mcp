{
  "name": "tcgen-st-test-mcp",
  "version": "0.8.2",
  "description": "Offline TcGen Structured Text semantic test MCP server backed by STruC++.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgileAutomationTechnologies/tcgen-st-test-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/AgileAutomationTechnologies/tcgen-st-test-mcp/issues"
  },
  "homepage": "https://github.com/AgileAutomationTechnologies/tcgen-st-test-mcp#readme",
  "bin": {
    "tcgen-st-test": "./dist/cli/main.js",
    "tcgen-st-test-mcp": "./dist/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "npm run build && node scripts/build-bundle.mjs",
    "build:exe": "npm run bundle && pkg dist/tcgen-st-test-mcp.cjs --no-bytecode --public-packages \"*\" --public --targets node22-win-x64 --output dist/tcgen-st-test-mcp.exe --compress GZip",
    "export:semantic-report-contract": "npm run build && node scripts/export-semantic-report-contract.mjs",
    "fixtures": "node scripts/run-fixtures.mjs",
    "pack:check": "npm run build:exe && node scripts/check-package.mjs && node scripts/smoke-bundle.mjs && node scripts/smoke-exe.mjs",
    "prepack": "npm run build:exe",
    "smoke:mcp": "node scripts/smoke-mcp.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test && npm run bundle",
    "verify:native": "npm run build && npm run fixtures && npm run smoke:mcp"
  },
  "files": [
    "dist/",
    "examples/",
    "scripts/",
    "schemas/",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "keywords": [
    "twincat",
    "structured-text",
    "mcp",
    "strucpp",
    "tcgen"
  ],
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@yao-pkg/pkg": "6.20.0",
    "esbuild": "0.27.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  }
}
